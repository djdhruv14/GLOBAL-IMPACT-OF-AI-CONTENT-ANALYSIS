    <worksheet name='Sheet 4'>
      <table>
        <view>
          <datasources>
            <datasource caption='Global_AI_Content_Impact_Dataset' name='federated.1ny17930slh38y1c8faxu06q0bso' />
          </datasources>
          <datasource-dependencies datasource='federated.1ny17930slh38y1c8faxu06q0bso'>
            <column datatype='real' name='[AI Adoption Rate (%)]' role='measure' type='quantitative' />
            <column datatype='real' name='[AI-Generated Content Volume (TBs per year)]' role='measure' type='quantitative' />
            <column caption='Adoption × Revenue' datatype='real' name='[Calculation_2352849389068967936]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI Adoption Rate (%)], [Revenue Increase Due to AI (%)])' />
            </column>
            <column caption='Adoption × Content Volume' datatype='real' name='[Calculation_2352849389069631489]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI Adoption Rate (%)], [AI-Generated Content Volume (TBs per year)])' />
            </column>
            <column caption='Adoption × Collaboration' datatype='real' name='[Calculation_2352849389076942856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI Adoption Rate (%)], [Human-AI Collaboration Rate (%)])' />
            </column>
            <column caption='Adoption × Job Loss' datatype='real' name='[Calculation_2352849389077274633]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI Adoption Rate (%)], [Job Loss Due to AI (%)])' />
            </column>
            <column caption='Content Volume × Revenue' datatype='real' name='[Calculation_2352849389077368842]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI-Generated Content Volume (TBs per year)], [Revenue Increase Due to AI (%)])' />
            </column>
            <column caption='Content Volume × Collaboration' datatype='real' name='[Calculation_2352849389077434379]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI-Generated Content Volume (TBs per year)], [Human-AI Collaboration Rate (%)])' />
            </column>
            <column caption='Content Volume × Job Loss' datatype='real' name='[Calculation_2352849389077557260]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([AI-Generated Content Volume (TBs per year)], [Job Loss Due to AI (%)])' />
            </column>
            <column caption='Revenue × Collaboration' datatype='real' name='[Calculation_2352849389077647373]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR([Revenue Increase Due to AI (%)], [Human-AI Collaboration Rate (%)])' />
            </column>
            <column caption='Revenue × Job Loss' datatype='real' name='[Calculation_2352849389077704718]' role='measure' type='quantitative'>
